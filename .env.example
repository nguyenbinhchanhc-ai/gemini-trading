# === GEMINI WEB TO API COOKIES CONFIGURATION ===
# Lấy từ gemini.google.com (F12 -> Application -> Cookies)
GEMINI_1PSID=your___Secure-1PSID_cookie_here
GEMINI_1PSIDTS=your___Secure-1PSIDTS_cookie_here
GEMINI_REFRESH_INTERVAL=30
GEMINI_MAX_RETRIES=3
GEMINI_TEMPORARY=false

# === TRADING BOT CONFIGURATION ===
# Cổng chạy ứng dụng (Render tự động cung cấp biến PORT này)
PORT=10000

# Cấu hình OKX API (Để trống nếu chỉ chạy Paper Trading - Giao dịch giả lập)
OKX_API_KEY=
OKX_API_SECRET=
OKX_API_PASSWORD=
# Chạy trên tài khoản Demo của OKX (True/False)
OKX_USE_DEMO=true

# Thông tin giao dịch
TRADE_SYMBOL=BTC/USDT
# Khung thời gian phân tích: 1m, 5m, 15m, 1h, 4h, 1d
TIMEFRAME=1h
# Khoảng thời gian tự động phân tích và chạy bot (phút)
ANALYSIS_INTERVAL_MINUTES=60
